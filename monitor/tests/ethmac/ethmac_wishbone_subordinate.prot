// ARGS: --wave ethmac/ethmac.fst --instances tb_ethernet:WBSubordinate --sample-posedge tb_ethernet.wb_clk --show-waveform-time --time-unit ns

// Note: one clock cycle is 30ns in the waveform
// Total of ~31,620,000 clock cycles in the waveform (waveform is 949899798 ns long)
// Note: on my machine (using `cargo run` with a debug build), 
// it takes ~7 mins 22 seconds for the monitor handle the first 12,500 clock cycles 
// in the waveform before the process gets killed
// TODO: run using release build / test on Havarti

// Wishbone B3 (Classic mode) subordinate
struct WBSubordinate {
    // Cycle is high anytime an active pipeline session is occurring
    in eth_sl_wb_cyc_i: u1,

    // Strobe is high when there is a request to the subordinate
    // (akin to Valid in AXI-Lite, i.e. they indicate the manager
    // has something to transfer)
    in eth_sl_wb_stb_i: u1,

    // Write-enable (true for write-requests)
    in eth_sl_wb_we_i: u1,

    // Address of the request
    in eth_sl_wb_adr_i: u32,

    // Data to be written
    in eth_sl_wb_dat_i: u32,

    // Reset signal
    in wb_rst: u1,

    // Response from the subordinate, indicating that the request
    // has been fulfilled.
    out eth_sl_wb_ack_o: u1,

    // Data returned by the subordinate to the manager
    // This is valid only when ACK is true
    out eth_sl_wb_dat_o: u32,
}

// Both cyc & stb are low when the subordinate is idle,
// everything else is DontCare
#[idle]
prot idle<DUT: WBSubordinate>() {
    // Reset signal is 0 (to distinguish the `idle` & `reset` protocols)
    DUT.wb_rst := 1'b0;  
    DUT.eth_sl_wb_cyc_i  := 1'b0;
    DUT.eth_sl_wb_stb_i  := 1'b0;
    DUT.eth_sl_wb_we_i   := X;
    DUT.eth_sl_wb_adr_i := X;
    DUT.eth_sl_wb_dat_i := X;
    step();
}

// Resets the subordinate
prot reset<DUT: WBSubordinate>() {
    // Reset signal is 1
    DUT.wb_rst := 1'b1;

    // Wishbone spec (Rule 3.20): CYC & STB must be 0 when RST is 1, 
    // all other signals are undefined (DontCare)
    DUT.eth_sl_wb_cyc_i := 1'b0;
    DUT.eth_sl_wb_stb_i := 1'b0;
    DUT.eth_sl_wb_we_i := X;
    DUT.eth_sl_wb_adr_i := X;
    DUT.eth_sl_wb_dat_i := X;

    step();
}

// Writes a `data` value to the subordinate
prot write<DUT: WBSubordinate>(addr: u32, data: u32, num_cycles: uint) {
    DUT.eth_sl_wb_cyc_i := 1'b1;
    // Wait a variable no. of cycles until manager sets `stb` to 1
    repeat num_cycles iterations {
        DUT.eth_sl_wb_stb_i := 1'b0;
        step();
    }
    DUT.eth_sl_wb_stb_i := 1'b1;
    DUT.eth_sl_wb_we_i := 1'b1;
    DUT.eth_sl_wb_adr_i := addr;
    DUT.eth_sl_wb_dat_i := data;

    // Wait till the subordinate Acks
    while (DUT.eth_sl_wb_ack_o == 1'b0) {
        step();
    }
    // ACK = 1 is sustained for one cycle
    step();
     
    // The DUT takes one more cycle to set CYC and STB to become 0 
    step();

    // After ACK, CYC and STB become 0 (section 3.1.3.1).
    // Per Rule 3.60, once STB is low, the address/data/WE don't 
    // contain semantically valid values, so they can be DontCare.
    DUT.eth_sl_wb_cyc_i := 1'b0;
    DUT.eth_sl_wb_stb_i := 1'b0;
    DUT.eth_sl_wb_we_i := X;
    DUT.eth_sl_wb_adr_i := X;
    DUT.eth_sl_wb_dat_i := X;
    
    // Wishbone spec says that after CYC and STB go to 0,
    // ACK should be set to 0 (Rule 3.5). 
    assert_eq(DUT.eth_sl_wb_ack_o, 1'b0);
    step();
}

// Reads a value from the subordinate
// (the `data` is conveyed via output parameters)
prot read<DUT: WBSubordinate>(addr: u32, data: u32, num_cycles: uint) {
    DUT.eth_sl_wb_cyc_i := 1'b1;
    // Wait a variable no. of cycles until manager sets `stb` to 1
    repeat num_cycles iterations {
        step();
    }
    DUT.eth_sl_wb_stb_i := 1'b1;
    DUT.eth_sl_wb_we_i := 1'b0;
    DUT.eth_sl_wb_adr_i := addr;

    // Input data to the subordinate during reads is DontCare
    DUT.eth_sl_wb_dat_i := X;

    // Wait for subordinate to Ack
    while (DUT.eth_sl_wb_ack_o == 1'b0) {
        step();
    }
    // ACK = 1 is sustained for one cycle
    step();

    // ACK is now high, and data is valid in the same cycle as ACK
    // (Rule 3.65 from Wishbone spec: "slave interfaces must qualify DAT_O with ACK_O",
    // i.e. data is only valid when ACK is high)
    assert_eq(DUT.eth_sl_wb_dat_o, data);

    // The DUT takes one more cycle to set CYC and STB to become 0
    step();
    
    // After ACK, CYC and STB become 0 (section 3.1.3.1).
    // Per Rule 3.60, once STB is low, the address/data/WE don't 
    // contain semantically valid values, so they can be DontCare.
    DUT.eth_sl_wb_cyc_i := 1'b0;
    DUT.eth_sl_wb_stb_i := 1'b0;
    DUT.eth_sl_wb_we_i := X;
    DUT.eth_sl_wb_adr_i := X;
    DUT.eth_sl_wb_dat_i := X;
    
    // Wishbone spec says that after CYC and STB go to 0,
    // ACK should be set to 0 (Rule 3.50). 
    assert_eq(DUT.eth_sl_wb_ack_o, 1'b0);
    step();
}
