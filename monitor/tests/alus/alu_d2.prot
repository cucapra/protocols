// ARGS: --wave alus/alu_d2.fst --instances alu_d2:ALU 
struct ALU {
  in a: u32,
  in b: u32,
  in op: u2,
  out s: u32,
}

prot add<DUT: ALU>(a: u32, b: u32, s: u32) {
  DUT.a := a;
  DUT.b := b;
  DUT.op := 2'b00;
  
  step();
  fork();
  
  DUT.a := X;
  DUT.b := X;
  DUT.op := X;

  step();
  
  DUT.a := X;
  DUT.b := X;
  DUT.op := X;

  assert_eq(s, DUT.s);
  step();
}

prot sub<DUT: ALU>(a: u32, b: u32, s: u32) {
  DUT.a := a;
  DUT.b := b;
  DUT.op := 2'b01;
  
  step();
  fork();
  
  DUT.a := X;
  DUT.b := X;
  DUT.op := X;

  step();

  DUT.a := X;
  DUT.b := X;
  DUT.op := X;

  assert_eq(s, DUT.s);
  step();
}

prot and<DUT: ALU>(a: u32, b: u32, s: u32) {
  DUT.a := a;
  DUT.b := b;
  DUT.op := 2'b10;
  
  step();
  fork();
  
  DUT.a := X;
  DUT.b := X;
  DUT.op := X;

  step();

  DUT.a := X;
  DUT.b := X;
  DUT.op := X;
  
  assert_eq(s, DUT.s);
  step();
}

prot or<DUT: ALU>(a: u32, b: u32, s: u32) {
  DUT.a := a;
  DUT.b := b;
  DUT.op := 2'b11;

  step();
  fork();
  
  DUT.a := X;
  DUT.b := X;
  DUT.op := X;

  step();

  DUT.a := X;
  DUT.b := X;
  DUT.op := X;
  
  assert_eq(s, DUT.s);
  step();
}