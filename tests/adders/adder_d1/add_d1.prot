// maps to a verilog design
struct Adder {
  in a: u32,
  in b: u32,
  out s: u32,
}

prot add<DUT: Adder>(a: u32, b: u32, s: u32) {
  DUT.a := a;
  DUT.b := b;
  step();
  DUT.a := X;
  DUT.b := X;
  assert_eq(s, DUT.s);
  fork();
  step();
}

prot add_fork_early<DUT: Adder>(a: u32, b: u32, s: u32) {
  DUT.a := a;
  DUT.b := b;
  step();
  fork();
  DUT.a := X;
  DUT.b := X;
  assert_eq(s, DUT.s);
  step();
}

prot add_incorrect<DUT: Adder>(a: u32, b: u32, s: u32) {
  DUT.a := a;
  DUT.b := b;
  step();
  DUT.a := a;
  DUT.b := b;
  assert_eq(s, DUT.s);
  fork();
  step();
}

prot add_incorrect_implicit<DUT: Adder>(a: u32, b: u32, s: u32) {
  DUT.a := a;
  DUT.b := b;
  step();

  // missing DontCare assignments to DUT.a and DUT.b

  assert_eq(s, DUT.s);
  fork();
  step();
}

prot wait_and_add<DUT: Adder>(a: u32, b: u32, s: u32) {

  step();

  fork();

  step();

  DUT.a := a;
  DUT.b := b;

  step();

  assert_eq(s, DUT.s);
  step();
}

// (in a bit of a roundabout way), check that a == 2, and if so reset DUT.a to 0
// applying a first and then observing DUT.a allows us to stay well-formed
prot assign_after_observation<DUT : Adder>(a: u32, b: u32, s: u32) {
  DUT.a := a;

  // set DUT.a to 0 if DUT.a == a == 2
  if (DUT.a == 32'b10) {
    // this branch will fail
    DUT.a := 32'b0;
  }
  DUT.b := b;

  step();

  DUT.a := X;
  DUT.b := X;
  assert_eq(s, DUT.s);

  fork();
  step();
}
