// trace 0
trace {
    reset();  // [time: 0ns -> 25ns]
    idle();  // [time: 25ns -> 50ns]
    push(1);  // [time: 50ns -> 75ns]
    push(2);  // [time: 75ns -> 100ns]
    push(3);  // [time: 100ns -> 125ns]
    push(4);  // [time: 125ns -> 150ns]
    push(5);  // [time: 150ns -> 175ns]
    push(6);  // [time: 175ns -> 200ns]
    push(7);  // [time: 200ns -> 200ns]
}
// trace 0
trace {
    reset();  // [time: 0ns -> 25ns]
}

// trace 1
trace {
    reset();  // [time: 0ns -> 25ns]
}

// trace 2
