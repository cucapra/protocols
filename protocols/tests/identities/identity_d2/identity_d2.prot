struct Identity {
  in a: u32,
  out s: u32,
}

prot multiple_assign<DUT: Identity>(a: u32, s: u32) {
  // If multiple instances of this protocol are run, this will pass if and only if
  // both instances pass the same integer value for parameter a. 
  DUT.a := a;
  step();
  fork();
  DUT.a := a;
  step();
  assert_eq(s, DUT.s);
  step();
}

