// maps to a verilog design
struct Adder {
  in a: u32,
  in b: u32,
  out s: u32,
}

prot add<DUT: Adder>(a: u32, b: u32, s: u32) {
  DUT.a := a;
  DUT.b := b;
  step();
  DUT.a := X;
  DUT.b := X;
  assert_eq(s, DUT.s);
  fork();
  step();
}

prot add_fork_early<DUT: Adder>(a: u32, b: u32, s: u32) {
  DUT.a := a;
  DUT.b := b;
  step();
  fork();
  DUT.a := X;
  DUT.b := X;
  assert_eq(s, DUT.s);
  step();
}

prot add_incorrect<DUT: Adder>(a: u32, b: u32, s: u32) {
  DUT.a := a;
  DUT.b := b;
  step();
  DUT.a := a;
  DUT.b := b;
  assert_eq(s, DUT.s);
  fork();
  step();
}

prot add_incorrect_implicit<DUT: Adder>(a: u32, b: u32, s: u32) {
  DUT.a := a;
  DUT.b := b;
  step();

  // missing DontCare assignments to DUT.a and DUT.b

  assert_eq(s, DUT.s);
  fork();
  step();
}

prot wait_and_add<DUT: Adder>(a: u32, b: u32, s: u32) {

  step();

  fork();

  step();

  DUT.a := a;
  DUT.b := b;

  step();

  assert_eq(s, DUT.s);
  step();
}