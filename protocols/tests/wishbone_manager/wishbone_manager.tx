// ARGS: --verilog wishbone_manager/hbexec.v --protocol=wishbone_manager/wishbone_manager.prot --module hbexec
trace {
    reset();

    // Write 0xDEADBEEF to address 16 = 0x10
    write(16, 0xDEADBEEF);

    // Read from address 17 = 0x11; subordinate returns 0xCAFEF00D
    read(17, 0xCAFEF00D);

    // Write 0xABCD1234 to address 18 = 0x12
    write(18, 0xABCD1234);

    idle();
}
