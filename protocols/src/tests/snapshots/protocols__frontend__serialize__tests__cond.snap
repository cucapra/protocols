source: protocols/src/frontend/serialize.rs
expression: content
---
struct Multiplier {
  in a: u32,
  in b: u32,
  out c: u1,
  out s: u32,
}

prot mul<dut: Multiplier>(a: u32, b: u32, s: u32) {
  dut.a := a;
  dut.b := b;
  step();
  step();
  fork();
  dut.a := X;
  dut.b := X;
  step();
  if 4'd8 == 4'd0 {
    step();
  } else {
    fork();
  }
  assert_eq(dut.c, 1'd1);
  assert_eq(s, dut.s);
  step();
}
