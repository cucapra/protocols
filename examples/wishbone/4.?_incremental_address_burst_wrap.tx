trace {
  // to make this work with RTL, we need to reset
  reset();
  // we have to use the SRAM address to make this work with our RTL
  // the last write should go to the base address
  write_burst_increment_wrap_4(0b1111, 0x4000000, [0x1111, 0x2222, 0x3333, 0x4444, 0x5555]);
  // extra idle cycle to make things look better on the signal trace
  idle_no_cycle();
}
